{
  "name": "mgr-method",
  "version": "0.3.6",
  "description": "MGR — Método Governado por Rastreabilidade: framework de desenvolvimento dirigido por especificação (plan/develop/qa) para agentes de código, portável entre Claude Code e GitHub Copilot.",
  "type": "module",
  "bin": {
    "mgr": "bin/mgr.cjs",
    "mgr-method": "bin/mgr.cjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/mgr.cjs",
    "dist/",
    "skills/",
    "shared/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info",
    "validate": "node bin/mgr.js validate",
    "build": "esbuild bin/mgr.js --bundle --minify --platform=node --format=esm --external:@clack/prompts --external:picocolors --outfile=dist/mgr.min.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "github-copilot",
    "spec-driven-development",
    "hexagonal"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Mauri Reis <maurigre@gmail.com> (https://github.com/maurigre)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maurigre/mgr-method.git"
  },
  "homepage": "https://github.com/maurigre/mgr-method#readme",
  "bugs": {
    "url": "https://github.com/maurigre/mgr-method/issues"
},
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
